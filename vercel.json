{
  "version": 2,
  "name": "validation-deploy",
  "alias": ["pipeline-ppl-080523.agentifai.io"],
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
